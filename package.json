{
  "name": "placeholder-model-1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run --coverage",
    "test:pixelmatch": "node tests/pixelmatch-check.mjs",
    "test:chunks": "playwright test tests/chunk-splitting.network.spec.ts",
    "test:cross-browser": "playwright test",
    "test:smoke": "playwright test tests/cross-browser.smoke.spec.ts",
    "test:visual": "playwright test tests/visual-regression.spec.ts --workers=1",
    "test:visual:update": "playwright test tests/visual-regression.spec.ts --update-snapshots --workers=1",
    "perf:compare": "node analysis/perf/compare-results.mjs analysis/perf analysis/perf/comparison-report.json",
    "security:audit": "npm audit --omit=dev --audit-level=moderate",
    "security:scan": "npm run lint && npm run security:audit",
    "test:ci": "npm run test:unit && npm run test:smoke && npm run test:chunks && npm run test:visual"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.2.1",
    "bcryptjs": "^3.0.3",
    "d3-geo": "^3.1.1",
    "d3-interpolate": "^3.0.1",
    "framer-motion": "^12.35.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "moment-timezone": "^0.6.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
