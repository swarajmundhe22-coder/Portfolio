{
  "name": "placeholder-model-1",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "cf:dev": "npx wrangler dev",
    "cf:deploy": "npm run build && npx wrangler deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1",
    "storybook:build": "storybook build",
    "test:unit": "vitest run --coverage",
    "test:pixelmatch": "node tests/pixelmatch-check.mjs",
    "test:chunks": "playwright test tests/chunk-splitting.network.spec.ts",
    "test:cross-browser": "playwright test",
    "test:smoke": "playwright test tests/cross-browser.smoke.spec.ts",
    "test:animated-list:perm": "playwright test tests/animated-list.permutation.spec.ts",
    "test:labs:e2e": "playwright test tests/labs.breakpoints.e2e.spec.ts",
    "test:visual": "playwright test tests/visual-regression.spec.ts --workers=1",
    "test:visual:update": "playwright test tests/visual-regression.spec.ts --update-snapshots --workers=1",
    "test:video:visual": "playwright test -c playwright.video-visual.config.ts tests/video-frame-visual.spec.ts",
    "test:video:visual:update": "playwright test -c playwright.video-visual.config.ts tests/video-frame-visual.spec.ts --update-snapshots",
    "test:video:visual:matrix": "node analysis/video/run-video-visual-suite.mjs",
    "test:storybook:visual": "node analysis/storybook/run-storybook-visual-comparison.mjs --mode=check",
    "test:storybook:visual:update": "node analysis/storybook/run-storybook-visual-comparison.mjs --mode=update",
    "test:storybook:keyframes": "npm run test:storybook:visual",
    "test:storybook:keyframes:update": "npm run test:storybook:visual:update",
    "quality:lighthouse": "node analysis/lighthouse/run-lighthouse-audits.mjs",
    "quality:lighthouse:ci": "node analysis/lighthouse/run-lighthouse-audits.mjs --mode=ci",
    "perf:fps": "node analysis/perf/profile-fps-matrix.mjs",
    "perf:fps:strict": "node analysis/perf/profile-fps-matrix.mjs http://127.0.0.1:5173/ analysis/perf/fps-matrix-report.json 58 4200 2",
    "perf:fps:gate": "node analysis/perf/assert-fps-gate.mjs analysis/perf/fps-matrix-report.json 58",
    "perf:runtime:gate": "node analysis/perf/assert-runtime-regression-gate.mjs analysis/perf/baseline analysis/perf 5",
    "perf:fps:ci": "npm.cmd run perf:fps:strict && npm.cmd run perf:fps:gate",
    "perf:fps:compare": "node analysis/perf/compare-fps-matrix.mjs",
    "perf:compare": "node analysis/perf/compare-results.mjs analysis/perf analysis/perf/comparison-report.json",
    "security:audit": "npm audit --omit=dev --audit-level=moderate",
    "security:scan": "npm run lint && npm run security:audit",
    "test:ci": "npm run test:unit && npm run test:smoke && npm run test:labs:e2e && npm run test:chunks && npm run test:visual && npm run perf:runtime:gate"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/gsap": "^1.20.2",
    "bcryptjs": "^3.0.3",
    "d3-geo": "^3.1.1",
    "d3-interpolate": "^3.0.1",
    "framer-motion": "^12.35.0",
    "gsap": "^3.14.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "moment-timezone": "^0.6.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-interpolate": "^3.0.4",
    "@types/node": "^24.10.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jimp": "^1.6.1",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "sharp": "^0.34.5",
    "storybook": "^10.3.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
